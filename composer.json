{
	"name": "davitec/dv-sso-auth",
	"description": "SSO authentication for TYPO3 CMS with Shibboleth-focused defaults",
	"license": [
		"GPL-2.0-or-later"
	],
	"type": "typo3-cms-extension",
	"version": "1.0.1",
	"authors": [
		{
			"name": "Davitec GmbH",
			"homepage": "https://www.davitec.de/",
			"role": "Maintainer"
		}
	],
	"homepage": "https://www.davitec.de/",
	"require": {
		"php": "^8.1 || ^8.2 || ^8.3 || ^8.4 || ^8.5",
		"typo3/cms-core": "^12.4 || ^13.4",
		"typo3/cms-backend": "^12.4 || ^13.4",
		"typo3/cms-extbase": "^12.4 || ^13.4",
		"typo3/cms-frontend": "^12.4 || ^13.4"
	},
	"autoload": {
		"psr-4": {
			"Davitec\\DvSsoAuth\\": "Classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Davitec\\DvSsoAuth\\Tests\\": "Tests/"
		}
	},
	"require-dev": {
		"typo3/testing-framework": "^8.0 || ^9.0",
		"phpunit/phpunit": "^10.5 || ^11.0"
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "dv_sso_auth"
		}
	}
}
